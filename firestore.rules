rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null;
    }

    function registrationSettingsPath() {
      return /databases/$(database)/documents/siteSettings/registrationOpen;
    }

    function isCampOpen(camp) {
      return !exists(registrationSettingsPath())
        || (
          camp == '青年領袖營'
          && get(registrationSettingsPath()).data.youthCamp == true
        )
        || (
          camp == '暑期兒童營'
          && get(registrationSettingsPath()).data.kidsCamp == true
        );
    }

    function hasValidRegistrationSettings() {
      return request.resource.data.keys().hasAll([
          'youthCamp',
          'kidsCamp',
          'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'youthCamp',
          'kidsCamp',
          'updatedAt'
        ])
        && request.resource.data.youthCamp is bool
        && request.resource.data.kidsCamp is bool
        && request.resource.data.updatedAt == request.time;
    }

    function hasValidRegistrationFields() {
      let required = [
        'camp',
        'name',
        'gender',
        'nationalId',
        'birthDate',
        'address',
        'phone',
        'email',
        'church',
        'transport',
        'transportOther',
        'diet',
        'dietOther',
        'shirtSize',
        'age',
        'isMinor',
        'hasGuardianConsent',
        'guardianConsentPath',
        'guardianConsentUrl',
        'termsAccepted',
        'createdAt'
      ];

      return request.resource.data.keys().hasAll(required)
        && request.resource.data.keys().hasOnly(required)
        && request.resource.data.camp in ['青年領袖營', '暑期兒童營']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50
        && request.resource.data.gender in ['男', '女', '保留']
        && request.resource.data.nationalId is string
        && request.resource.data.nationalId.matches('^[A-Z][12][0-9]{8}$')
        && request.resource.data.birthDate is string
        && request.resource.data.address is string
        && request.resource.data.address.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 150
        && request.resource.data.church is string
        && request.resource.data.church.size() <= 100
        && request.resource.data.transport is string
        && request.resource.data.transportOther is string
        && request.resource.data.diet is string
        && request.resource.data.dietOther is string
        && request.resource.data.shirtSize in ['XS', 'S', 'M', 'L', 'XL', '2XL', '3XL']
        && request.resource.data.age is int
        && request.resource.data.age >= 0
        && request.resource.data.age <= 120
        && request.resource.data.isMinor is bool
        && request.resource.data.isMinor == (request.resource.data.age < 18)
        && request.resource.data.hasGuardianConsent is bool
        && request.resource.data.guardianConsentPath is string
        && request.resource.data.guardianConsentUrl is string
        && request.resource.data.termsAccepted == true
        && request.resource.data.createdAt == request.time
        && (
          !request.resource.data.isMinor
          || (
            request.resource.data.hasGuardianConsent == true
            && request.resource.data.guardianConsentPath.size() > 0
          )
        );
    }

    match /registrations/{registrationId} {
      allow create: if hasValidRegistrationFields()
        && isCampOpen(request.resource.data.camp);
      allow read, update, delete: if isAdmin();
    }

    match /siteSettings/registrationOpen {
      allow read: if true;
      allow create, update: if isAdmin() && hasValidRegistrationSettings();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
